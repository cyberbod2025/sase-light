# Configuración LOCAL de Supabase para SASE — plantilla versionada (SIN valores reales).
#
# Uso:
#   1) Copiar este archivo a `.env` (ya ignorado por git).
#   2) Rellenar los valores reales SOLO en `.env`.
#   3) Exportar las variables al entorno antes de correr la app
#      (la app las lee con System.getenv / NSProcessInfo, no carga `.env` sola):
#        - PowerShell: $env:SASE_SUPABASE_ANON_KEY="..."  (por variable)
#        - bash:       set -a; . ./.env; set +a
#
# NUNCA usar la service_role key: SupabaseConfiguration la rechaza y jamás debe
# llegar a un cliente. Solo la clave publicable (anon).

# MOCK (predeterminado) | SUPABASE
SASE_AUTH_BACKEND=SUPABASE

# URL del proyecto (SASE-Light)
SASE_SUPABASE_URL=https://plyjvvpkaafnkxmmqkbh.supabase.co

# Clave publicable (anon) del proyecto — NO service_role. Pegar en `.env`, no aquí.
SASE_SUPABASE_ANON_KEY=
